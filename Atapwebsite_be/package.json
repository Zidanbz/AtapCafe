{
  "name": "atapwebsite-be",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:integration": "tsx scripts/setup-test-db.ts && RUN_INTEGRATION_TESTS=1 tsx --test src/**/*.integration.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5"
  }
}
